@page
@model MyCoreApp.Pages.IndexModel

<h2>Sprawdź pogodę</h2>

<form method="post">
    <input type="text" asp-for="City" placeholder="Podaj miasto" />
    <button type="submit">Pobierz</button>
</form>

@if (Model.Weather != null)
{
    <div style="margin-top:20px;">
        <p><strong>Miasto:</strong> @Model.Weather.Name</p>
        <p><strong>Temperatura:</strong> @Model.Weather.Main.Temp °C</p>
        <p><strong>Opis:</strong> @Model.Weather.Weather[0].Description</p>
        <p><strong>Wilgotność:</strong> @Model.Weather.Main.Humidity %</p>
        <p><strong>Wiatr:</strong> @Model.Weather.Wind.Speed m/s</p>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <p style="color:red; margin-top:10px;">@Model.ErrorMessage</p>
}