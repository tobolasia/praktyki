@page
@model MyCoreApp.Pages.HistoryModel

<h2>Historia odczytów pogodowych</h2>

<form method="get" class="mb-3">

    <label>Miasto:</label>
    <input type="text" name="City" value="@Model.City" class="form-control" />

    <label>Data od:</label>
    <input type="date" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />

    <label>Data do:</label>
    <input type="date" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />

    <label>Sortowanie:</label>
    <select name="SortBy" class="form-control">
        <option value="date_desc" selected="@("date_desc" == Model.SortBy)">Od najnowszych</option>
        <option value="date_asc" selected="@("date_asc" == Model.SortBy)">Od najstarszych</option>
        <option value="temp_desc" selected="@("temp_desc" == Model.SortBy)">Temperatura malejąco</option>
        <option value="temp_asc" selected="@("temp_asc" == Model.SortBy)">Temperatura rosnąco</option>
    </select>

    <button type="submit" class="btn btn-primary mt-2">Filtruj</button>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Miasto</th>
            <th>Temperatura</th>
            <th>Opis</th>
            <th>Wilgotność</th>
            <th>Wiatr</th>
            <th>Data</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Records)
        {
            <tr>
                <td>@item.City</td>
                <td>@item.Temperature °C</td>
                <td>@item.Description</td>
                <td>@item.Humidity %</td>
                <td>@item.WindSpeed m/s</td>
                <td>@item.CreatedAt.ToLocalTime()</td>
            </tr>
        }
    </tbody>
</table>