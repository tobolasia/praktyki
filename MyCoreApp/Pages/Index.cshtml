@page
@model MyCoreApp.Pages.IndexModel
@functions {
    public string GetAqiDescription(int aqi)
    {
        return aqi switch
        {
            1 => "Bardzo dobra",
            2 => "Dobra",
            3 => "Umiarkowana",
            4 => "Zła",
            5 => "Bardzo zła",
            _ => "Brak danych"
        };
    }
}

<h2>Sprawdź pogodę</h2>

<form method="post">
    <input type="text" asp-for="City" placeholder="Podaj miasto" />
    <button type="submit">Pobierz</button>
</form>

@if (Model.Weather != null)
{
    <div style="margin-top:20px;">
        <p><strong>Miasto<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="#1f1f1f"><path d="M0 0h24v24H0z" fill="none" /><path d="M12 12c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm6-1.8C18 6.57 15.35 4 12 4s-6 2.57-6 6.2c0 2.34 1.95 5.44 6 9.14 4.05-3.7 6-6.8 6-9.14zM12 2c4.2 0 8 3.22 8 8.2 0 3.32-2.67 7.25-8 11.8-5.33-4.55-8-8.48-8-11.8C4 5.22 7.8 2 12 2z" /></svg>:</strong> @Model.Weather.Name</p>
        <p><strong>Temperatura<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="#1f1f1f"><path d="M0 0h24v24H0V0z" fill="none" /><path d="M15 13V5c0-1.66-1.34-3-3-3S9 3.34 9 5v8c-1.21.91-2 2.37-2 4 0 2.76 2.24 5 5 5s5-2.24 5-5c0-1.63-.79-3.09-2-4zm-4-8c0-.55.45-1 1-1s1 .45 1 1h-1v1h1v2h-1v1h1v2h-2V5z" /></svg>:</strong> @Model.Weather.Main.Temp °C</p>
        <p><strong>Opis:</strong> @Model.Weather.Weather[0].Description</p>
        <p><strong>Wilgotność<svg xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 24 24" height="24px" viewBox="0 0 24 24" width="24px" fill="#1f1f1f"><rect fill="none" height="24" width="24" /><path d="M12,2c-5.33,4.55-8,8.48-8,11.8c0,4.98,3.8,8.2,8,8.2s8-3.22,8-8.2C20,10.48,17.33,6.55,12,2z M12,20c-3.35,0-6-2.57-6-6.2 c0-2.34,1.95-5.44,6-9.14c4.05,3.7,6,6.79,6,9.14C18,17.43,15.35,20,12,20z M7.83,14c0.37,0,0.67,0.26,0.74,0.62 c0.41,2.22,2.28,2.98,3.64,2.87c0.43-0.02,0.79,0.32,0.79,0.75c0,0.4-0.32,0.73-0.72,0.75c-2.13,0.13-4.62-1.09-5.19-4.12 C7.01,14.42,7.37,14,7.83,14z" /></svg>:</strong> @Model.Weather.Main.Humidity %</p>
        <p><strong>Wiatr<svg xmlns="http://www.w3.org/2000/svg" enable-background="new 0 0 24 24" height="24px" viewBox="0 0 24 24" width="24px" fill="#1f1f1f"><g><path d="M0,0h24v24H0V0z" fill="none" /></g><g><g><path d="M14.5,17c0,1.65-1.35,3-3,3s-3-1.35-3-3h2c0,0.55,0.45,1,1,1s1-0.45,1-1s-0.45-1-1-1H2v-2h9.5 C13.15,14,14.5,15.35,14.5,17z M19,6.5C19,4.57,17.43,3,15.5,3S12,4.57,12,6.5h2C14,5.67,14.67,5,15.5,5S17,5.67,17,6.5 S16.33,8,15.5,8H2v2h13.5C17.43,10,19,8.43,19,6.5z M18.5,11H2v2h16.5c0.83,0,1.5,0.67,1.5,1.5S19.33,16,18.5,16v2 c1.93,0,3.5-1.57,3.5-3.5S20.43,11,18.5,11z" /></g></g></svg>:</strong> @Model.Weather.Wind.Speed m/s</p>
    </div>
}

@if (Model.AirQuality != null)
{
    var item = Model.AirQuality.List[0];
    var aqi = item.Main.Aqi;
    var comp = item.Components;

    <h3 class="mt-4">Jakość powietrza</h3>

    <p><strong>AQI:</strong> @aqi (@GetAqiDescription(aqi))</p>

    <table class="table table-bordered w-50">
        <tr><td>PM2.5</td><td>@comp.Pm2_5 µg/m³</td></tr>
        <tr><td>PM10</td><td>@comp.Pm10 µg/m³</td></tr>
        <tr><td>NO₂</td><td>@comp.No2 µg/m³</td></tr>
        <tr><td>SO₂</td><td>@comp.So2 µg/m³</td></tr>
        <tr><td>O₃</td><td>@comp.O3 µg/m³</td></tr>
        <tr><td>CO</td><td>@comp.Co µg/m³</td></tr>
    </table>
}

@if (Model.Forecast != null)
{
    <h3 class="mt-4">Prognoza 5‑dniowa</h3>

    <div class="row">
        @foreach (var item in Model.Forecast.List)
        {
            <div class="col-md-3 border p-2 m-2">
                <strong>@item.DtTxt</strong><br />
                <span><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="#1f1f1f"><path d="M0 0h24v24H0V0z" fill="none" /><path d="M15 13V5c0-1.66-1.34-3-3-3S9 3.34 9 5v8c-1.21.91-2 2.37-2 4 0 2.76 2.24 5 5 5s5-2.24 5-5c0-1.63-.79-3.09-2-4zm-4-8c0-.55.45-1 1-1s1 .45 1 1h-1v1h1v2h-1v1h1v2h-2V5z" /></svg>@item.Main.Temp °C</span><br />
                <span>@item.Weather[0].Description</span><br />
                <span>Wiatr: @item.Wind.Speed m/s</span>
            </div>
        }
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <p style="color:red; margin-top:10px;">@Model.ErrorMessage</p>
}